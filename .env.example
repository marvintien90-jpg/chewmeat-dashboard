# .env.example — 本機開發環境變數範本
# 複製為 .env 並填入真實值：
#   cp .env.example .env
#
# .env 已加入 .gitignore，不會被提交至 Git

# ── Line Messaging API ─────────────────────────────────────────
# 取得位置：https://developers.line.biz/console/
#   → 選擇 Channel → Messaging API → Channel credentials

LINE_CHANNEL_SECRET=請填入32碼Channel_Secret
LINE_CHANNEL_ACCESS_TOKEN=請填入Channel_Access_Token_長期版

# 群組 ID → 門店名稱對應（JSON 格式）
# groupId 取得方式：Bot 收到第一則群組訊息時，webhook 事件 source.groupId 即為群組 ID
LINE_GROUP_STORE_MAP={"C群組ID1":"崇德店","C群組ID2":"美村店"}

# ── ngrok 免費帳號 Token ─────────────────────────────────────
# 取得：https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=請填入ngrok_authtoken

# ── 資料庫路徑 ─────────────────────────────────────────────────
# 與 Streamlit 共用同一個 SQLite，兩者都讀寫這個路徑
EDGE_DB_PATH=/tmp/edge_agent.db

# ── 其他設定 ───────────────────────────────────────────────────
PORT=8765
LINE_REPLY_ON_EVENT=true
