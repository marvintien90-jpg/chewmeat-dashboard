# .streamlit/secrets.toml.example
# 複製為 .streamlit/secrets.toml 並填入真實值（此檔不含機密，可提交 Git）
#
# Streamlit Cloud 設定方式：
#   App Settings → Secrets → 貼上 secrets.toml 內容
#
# 本地開發：
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   編輯 secrets.toml 填入真實值

# ── Line Messaging API ────────────────────────────────────────────
# 取得位置：Line Developers Console > Messaging API > Channel credentials
LINE_CHANNEL_SECRET       = "請填入 32 碼 Channel Secret"
LINE_CHANNEL_ACCESS_TOKEN = "請填入 Channel Access Token（建議使用長期 Token）"

# 群組 ID → 門店名稱 對應表（JSON 格式字串）
# Line groupId 格式：'C' 開頭 + 32 碼英數字（webhook 事件的 source.groupId）
# 可用 /api/groups 端點或 Streamlit 設定頁面管理
LINE_GROUP_STORE_MAP = '{"C1234567890abcdef1234567890abcdef": "崇德店", "C9876543210fedcba9876543210fedcba": "美村店"}'

# Webhook 伺服器 URL（部署 Render.com 後填入）
# 供 Streamlit Dashboard 呼叫 /api/events 時使用
LINE_WEBHOOK_SERVER_URL = "https://kerou-line-webhook.onrender.com"

# ── SQLite 資料庫路徑 ────────────────────────────────────────────
# 本地開發：填入本機路徑，與 line_webhook.py 使用同一個 DB
# Streamlit Cloud：留空（使用 /tmp/edge_agent.db，重啟後清空）
# EDGE_DB_PATH = "/Users/yourname/kerou/edge_agent.db"

# ── AI / 其他 API ────────────────────────────────────────────────
ANTHROPIC_API_KEY       = "sk-ant-xxxx"
GOOGLE_PLACES_API_KEY   = ""
SERPAPI_KEY             = ""
